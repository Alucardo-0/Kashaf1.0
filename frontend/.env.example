# ── Convex ────────────────────────────────────────────────────────────────
# These are set automatically by `bunx convex dev`.
# Fill them in manually if you are setting up without running dev first.
CONVEX_DEPLOYMENT=dev:your-project-name
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site

# ── Engine communication ───────────────────────────────────────────────────
# URL where the local Python engine is running
ENGINE_BASE_URL=http://localhost:8080

# Token the Python engine sends when calling back to us (callback auth).
# Must EXACTLY match ENGINE_CALLBACK_TOKEN in Convex Dashboard → Settings → Env Vars
ENGINE_CALLBACK_TOKEN=change-me-to-a-long-random-secret

# Token we send to authenticate our requests TO the Python engine.
# Must EXACTLY match the KASHAF_ENGINE_TOKEN env var used when starting the Python engine.
KASHAF_ENGINE_TOKEN=change-me-to-a-long-random-secret

# Public URL of this Next.js app — the engine uses this to send results back.
# In local dev: http://localhost:3000
# In production: https://your-deployed-domain.com
DNS_PUBLIC_URL=http://localhost:3000
