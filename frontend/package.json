{
  "name": "dns",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n front,convex,engine -c blue,green,yellow \"bun run dev:frontend\" \"bun run dev:backend\" \"bun run dev:engine\"",
    "dev:frontend": "next dev",
    "dev:backend": "convex dev",
    "dev:engine": "cd ../backend && KASHAF_ENGINE_TOKEN=4b2bfb837a96be21f43600cd1bdae057cd359d9e54bcf4803fd3e0fc1dfd88c3 .venv/Scripts/python -m integration.api --port 8080",
    "predev": "convex dev --until-success && convex dev --once --run-sh \"bun setup.mjs --once\" && convex dashboard",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern \"convex/_generated/**\""
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@convex-dev/auth": "^0.0.90",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.31.7",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.3",
    "input-otp": "^1.4.2",
    "lenis": "^1.3.17",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
