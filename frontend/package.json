    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
